# Firebase-Web-Config für die QR-Code-Live-Synchronisierung.
# Werte aus der Firebase Console: Projekteinstellungen -> Meine Apps -> Web-App.
# Für lokale Entwicklung: Datei nach ".env" kopieren und Werte eintragen (.env ist in .gitignore).
# Für Netlify: dieselben Variablen unter Site settings -> Environment variables eintragen.

REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_DATABASE_URL=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
